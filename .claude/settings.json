{
  "permissions": {
    "allow": [
      "Bash(./verify *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)", 
      "Bash(git push origin *)", 
      "Bash(git push -u origin *)", 
      "Bash(gh pr create*)", 
      "Bash(gh pr list*)", 
      "Bash(gh pr view*)" 
    ],
    "deny":  [ 
      "Bash(git push origin main*)", 
      "Bash(git push -u origin main*)", 
      "Bash(git push --force*)", 
      "Bash(git push -f*)", 
      "Bash(git push origin +*)", 
      "Bash(git push --delete*)", 
      "Bash(gh pr merge*)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf*)",
      "Read(./.env*)",
      "Read(./**/secrets*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pretool-deny.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/posttool-dirty.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/stop-gate.sh" }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/stop-gate.sh" }
        ]
      }
    ]
  }
}
